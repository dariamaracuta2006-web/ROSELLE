">grid-2</span><span> </span><span class="ͼv">img</span><span>,</span><br><span>.</span><span class="ͼs">grid-3</span><span> </span><span class="ͼv">img</span><span> {</span><br><span>    width: </span><span class="ͼq">100</span><span class="ͼn">%</span><span>;</span><br><span>    height: </span><span class="ͼq">300</span><span class="ͼn">px</span><span>;</span><br><span>    object-fit: </span><span class="ͼq">cover</span><span>;</span><br><span>    border-radius: </span><span class="ͼq">15</span><span class="ͼn">px</span><span>;</span><br><span>    transition: </span><span class="ͼq">0.4</span><span class="ͼn">s</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">grid-2</span><span> </span><span class="ͼv">img</span><span>:</span><span class="ͼs">hover</span><span>,</span><br><span>.</span><span class="ͼs">grid-3</span><span> </span><span class="ͼv">img</span><span>:</span><span class="ͼs">hover</span><span> {</span><br><span>    transform: </span><span class="ͼn">scale</span><span>(</span><span class="ͼq">1.05</span><span>);</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
