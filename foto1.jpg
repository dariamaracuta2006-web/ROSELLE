an><span>;</span><br><span>  grid-template-columns: </span><span class="ͼn">repeat</span><span>(</span><span class="ͼq">4</span><span>, </span><span class="ͼq">1</span><span class="ͼn">fr</span><span>);</span><br><span>  gap: </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">gallery-item</span><span> {</span><br><span>  border-radius: </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--radius</span><span>);</span><br><span>  overflow: </span><span class="ͼq">hidden</span><span>;</span><br><span>  border: </span><span class="ͼq">1</span><span class="ͼn">px</span><span> </span><span class="ͼq">solid</span><span> </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--line</span><span>);</span><br><span>  background: </span><span class="ͼq">white</span><span>;</span><br><span>  transition: </span><span class="ͼq">0.3</span><span class="ͼn">s</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">gallery-item</span><span>:</span><span class="ͼs">hover</span><span> {</span><br><span>  transform: </span><span class="ͼq">tra</span><span class="ͼn">nslateY</span><span>(</span><span class="ͼq">-5</span><span class="ͼn">px</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼs">gallery-photo</span><span> {</span><br><span>  width: </span><span class="ͼq">100</span><span class="ͼn">%</span><span>;</span><br><span>  height: </span><span class="ͼq">220</span><span class="ͼn">px</span><span>;</span><br><span>  object-fit: </span><span class="ͼq">cover</span><span>;</span><br><span>}</span><br><br><span class="ͼl">/* PRODUSE */</span><br><br><span>.</span><span class="ͼs">products-grid</span><span> {</span><br><span>  display: </span><span class="ͼq">grid</span><span>;</span><br><span>  grid-template-columns: </span><span class="ͼn">repeat</span><span>(</span><span class="ͼq">4</span><span>, </span><span class="ͼq">1</span><span class="ͼn">fr</span><span>);</span><br><span>  gap: </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">product-card</span><span> {</span><br><span>  border-radius: </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--radius</span><span>);</span><br><span>  overflow: </span><span class="ͼq">hidden</span><span>;</span><br><span>  border: </span><span class="ͼq">1</span><span class="ͼn">px</span><span> </span><span class="ͼq">solid</span><span> </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--line</span><span>);</span><br><span>  background: </span><span class="ͼq">white</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">product-photo</span><span> {</span><br><span>  width: </span><span class="ͼq">100</span><span class="ͼn">%</span><span>;</span><br><span>  </span><span class="ͼv">height</span><span>: </span><span class="ͼq">220</span><span class="ͼn">px</span><span>;</span><br><span>  object-fit: </span><span class="ͼq">cover</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">product-info</span><span> {</span><br><span>  padding: </span><span class="ͼq">15</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">price</span><span> {</span><br><span>  color: </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--accent</span><span>);</span><br><span>  font-weight: </span><span class="ͼq">bold</span><span>;</span><br><span>  margin-top: </span><span class="ͼq">10</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span class="ͼl">/* BUTTONS */</span><br><br><span>.</span><span class="ͼs">btn</span><span> {</span><br><span>  padding: </span><span class="ͼq">10</span><span class="ͼn">px</span><span> </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>  background: </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--accent</span><span>);</span><br><span>  color: </span><span class="ͼq">white</span><span>;</span><br><span>  border-radius: </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>  text-decoration: </span><span class="ͼq">none</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">btn-outline</span><span> {</span><br><span>  border: </span><span class="ͼq">1</span><span class="ͼn">px</span><span> </span><span class="ͼq">solid</span><span> </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--accent</span><span>);</span><br><span>  color: </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--accent</span><span>);</span><br><span>  background: </span><span class="ͼq">transparent</span><span>;</span><br><span>}</span><br><br><span class="ͼl">/* FOOTER */</span><br><br><span class="ͼv">footer</span><span> {</span><br><span>  text-align: </span><span class="ͼq">center</span><span>;</span><br><span>  padding: </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>  </span><span class="ͼv">col</span><span>or: #888;</span><br><span>  border-top: </span><span class="ͼq">1</span><span class="ͼn">px</span><span> </span><span class="ͼq">solid</span><span> </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--line</span><span>);</span><br><span>  margin-top: </span><span class="ͼq">40</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span>/</span><span class="ͼl">* RESPONSIVE */</span><br><br><span class="ͼn">@media</span><span> (max-width: </span><span class="ͼq">900</span><span class="ͼn">px</span><span>) {</span><br><span>  .</span><span class="ͼs">gallery-grid</span><span>,</span><br><span>  .</span><span class="ͼs">products-grid</span><span> {</span><br><span>    </span><span class="ͼv">grid-template-co</span><span>lumns: </span><span class="ͼn">repeat</span><span>(</span><span class="ͼq">2</span><span>, </span><span class="ͼq">1</span><span class="ͼn">fr</span><span>);</span><br><span>  }</span><br><span>}</span><br><br><span class="ͼn">@media</span><span> (max-width: </span><span class="ͼq">600</span><span class="ͼn">px</span><span>) {</span><br><span>  .</span><span class="ͼs">gallery-grid</span><span>,</span><br><span>  .</span><span class="ͼs">products-grid</span><span> {</span><br><span>    </span><span class="ͼv">grid-template-columns</span><span>: </span><span class="ͼq">1</span><span class="ͼn">fr</span><span>;</span><br><span>  }</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
