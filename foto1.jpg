span><span class="ͼq">48</span><span class="ͼn">px</span><span>;</span><br><span>  font-weight: </span><span class="ͼq">300</span><span>;</span><br><span>  letter-spacing: </span><span class="ͼq">4</span><span class="ͼn">px</span><span>;</span><br><span>  margin-bottom: </span><span class="ͼq">10</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">editorial-overlay</span><span> </span><span class="ͼv">p</span><span> {</span><br><span>  margin: </span><span class="ͼq">0</span><span>;</span><br><span>  font-size: </span><span class="ͼq">16</span><span class="ͼn">px</span><span>;</span><br><span>  line-height: </span><span class="ͼq">1.7</span><span>;</span><br><span>  color: #fff;</span><br><span>}</span><br><br><span class="ͼl">/* text card */</span><br><span>.</span><span class="ͼs">text-card</span><span> </span><span class="ͼv">h3</span><span> {</span><br><span>  font-size: </span><span class="ͼq">32</span><span class="ͼn">px</span><span>;</span><br><span>  margin-bottom: </span><span class="ͼq">14</span><span class="ͼn">px</span><span>;</span><br><span>  color: </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--text</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼs">text-card</span><span> </span><span class="ͼv">p</span><span> {</span><br><span>  font-size: </span><span class="ͼq">16</span><span class="ͼn">px</span><span>;</span><br><span>  color: </span><span class="ͼn">var</span><span>(</span><span class="ͼt">--muted</span><span>);</span><br><span>  margin-bottom: </span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>  line-height: </span><span class="ͼq">1.8</span><span>;</span><br><span>}</span><br><br><span class="ͼl">/* quote card */</span><br><span>.</span><span class="ͼs">quote-big</span><span> {</span><br><span>  font-size: </span><span class="ͼq">64</span><span class="ͼn">px</span><span>;</span><br><span>  line-height: </span><span c